<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_rel_don_tu_tree" model="ir.ui.view">
        <field name="name">view.rel.don.tu.tree</field>
        <field name="model">rel.don.tu</field>
        <field name="arch" type="xml">
            <tree string="Rel đơn từ" editable="bottom">
                <field name="employee_id"/>
                <field name="leave_more"/>
                <field name="date"/>
                <field name="status"/>
            </tree>
        </field>
    </record>

    <record id="action_rel_don_tu" model="ir.actions.act_window">
        <field name="name">Rel đơn từ</field>
        <field name="res_model">rel.don.tu</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>