<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_popup_invoice_pkl_choose_form" model="ir.ui.view">
        <field name="name">popup.invoice.pkl.choose.form</field>
        <field name="model">popup.invoice.pkl.choose</field>
        <field name="arch" type="xml">
            <form string="Chọn SO tạo Invoice, Packing List" edit="true">
                <group>
                    <field name="shipment_id" string="">
                        <tree editable="bottom" delete="0" create="0" class="custom_popup">
                            <field name="radio_tick" class="check-box" string=""/>
                            <field name="invoice_number" readonly="1"/>
                            <field name="so_cont_number" readonly="1"/>
                            <field name="date_shipment" readonly="1"/>
                            <field name="shipment_id" column_invisible="1"/>
                        </tree>
                    </field>
                    <field name="contract_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Xác nhận" class="btn-primary"/>
                    <button string="Hủy" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_popup_invoice_pkl_choose" model="ir.actions.act_window">
        <field name="name">Chọn SO tạo Invoice, Packing List</field>
        <field name="res_model">popup.invoice.pkl.choose</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>