<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_exp_config_port_tree" model="ir.ui.view">
        <field name="name">view.exp.config.port.tree</field>
        <field name="model">exp.config.port</field>
        <field name="arch" type="xml">
            <tree string="Danh mục cảng" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="type"/>
                <field name="country_id"/>
            </tree>
        </field>
    </record>

    <record id="action_exp_config_port" model="ir.actions.act_window">
        <field name="name">Danh mục cảng</field>
        <field name="res_model">exp.config.port</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>