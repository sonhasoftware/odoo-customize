<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_exp_co_bh_reminder_tree" model="ir.ui.view">
        <field name="name">view.exp.co.bh.reminder.tree</field>
        <field name="model">exp.co.bh.reminder</field>
        <field name="arch" type="xml">
            <tree string="Cấu hình nhắc mail CO, BH" editable="bottom">
                <field name="remind_type"/>
                <field name="noti_day"/>
                <field name="is_active"/>
            </tree>
        </field>
    </record>

    <record id="action_exp_co_bh_reminder" model="ir.actions.act_window">
        <field name="name">Công việc</field>
        <field name="res_model">exp.co.bh.reminder</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>