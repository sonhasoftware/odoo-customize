<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_exp_distribute_group_user_tree" model="ir.ui.view">
        <field name="name">view.exp.distribute.group.user.tree</field>
        <field name="model">exp.distribute.group.user</field>
        <field name="arch" type="xml">
            <tree string="Phân nhóm người dùng" editable="bottom">
                <field name="employee_id"/>
                <field name="group_id"/>
            </tree>
        </field>
    </record>

    <record id="view_exp_distribute_group_user_search" model="ir.ui.view">
        <field name="name">exp.distribute.group.user.search</field>
        <field name="model">exp.distribute.group.user</field>
        <field name="arch" type="xml">
            <search string="Tìm kiếm nhóm người dùng">
                <field name="employee_id" string="Nhân viên"/>
                <field name="group_id" string="Nhóm"/>
            </search>
        </field>
    </record>

    <record id="action_exp_distribute_group_user" model="ir.actions.act_window">
        <field name="name">Phân nhóm người dùng</field>
        <field name="res_model">exp.distribute.group.user</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>