<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_exp_config_country_tree" model="ir.ui.view">
        <field name="name">view.exp.config.country.tree</field>
        <field name="model">exp.config.country</field>
        <field name="arch" type="xml">
            <tree string="Danh mục quốc gia" editable="bottom">
                <field name="code"/>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="action_exp_config_country" model="ir.actions.act_window">
        <field name="name">Danh mục quốc gia</field>
        <field name="res_model">exp.config.country</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>