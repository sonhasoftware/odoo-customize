<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_exp_contract_api_tree" model="ir.ui.view">
        <field name="name">view.exp.contract.api.tree</field>
        <field name="model">exp.contract.api</field>
        <field name="arch" type="xml">
            <tree string="API hợp đồng" editable="bottom">
                <field name="url"/>
                <field name="code"/>
                <field name="user"/>
                <field name="password"/>
                <field name="error"/>
                <button name="action_download" string="Tải dữ liệu" type="object" class="oe_highlight"/>
            </tree>
        </field>
    </record>

    <record id="action_exp_contract_api" model="ir.actions.act_window">
        <field name="name">API hợp đồng</field>
        <field name="res_model">exp.contract.api</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>