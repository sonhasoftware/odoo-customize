<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_exp_document_type_tree" model="ir.ui.view">
        <field name="name">view.exp.document.type.tree</field>
        <field name="model">exp.document.type</field>
        <field name="arch" type="xml">
            <tree string="Loại chứng từ" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="action_exp_document_type" model="ir.actions.act_window">
        <field name="name">Loại chứng từ</field>
        <field name="res_model">exp.document.type</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>