<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_exp_config_data_tree" model="ir.ui.view">
        <field name="name">view.exp.config.data.tree</field>
        <field name="model">exp.config.data</field>
        <field name="arch" type="xml">
            <tree string="Dữ liệu danh mục" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="data"/>
                <field name="note"/>
            </tree>
        </field>
    </record>

    <record id="action_exp_config_data" model="ir.actions.act_window">
        <field name="name">Dữ liệu danh mục</field>
        <field name="res_model">exp.config.data</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>