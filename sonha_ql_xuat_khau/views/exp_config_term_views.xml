<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_exp_config_term_tree" model="ir.ui.view">
        <field name="name">view.exp.config.term.tree</field>
        <field name="model">exp.config.term</field>
        <field name="arch" type="xml">
            <tree string="Danh mục điều khoản thanh toán" editable="bottom">
                <field name="code"/>
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="action_exp_config_term" model="ir.actions.act_window">
        <field name="name">Danh mục điều khoản thanh toán</field>
        <field name="res_model">exp.config.term</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>