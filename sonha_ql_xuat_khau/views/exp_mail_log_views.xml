<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_exp_mail_log_tree" model="ir.ui.view">
            <field name="name">view.exp.mail.log.tree</field>
            <field name="model">exp.mail.log</field>
            <field name="arch" type="xml">
                <tree editable="bottom">
                    <field name="contract_id"/>
                    <field name="note"/>
                    <field name="send_date"/>
                </tree>
            </field>
        </record>

        <record id="action_exp_mail_log" model="ir.actions.act_window">
            <field name="name">Log mail</field>
            <field name="res_model">exp.mail.log</field>
            <field name="view_mode">tree</field>
        </record>
    </data>
</odoo>