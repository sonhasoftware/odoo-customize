<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_exp_state_transition_rule_tree" model="ir.ui.view">
        <field name="name">view.exp.state.transition.rule.tree</field>
        <field name="model">exp.state.transition.rule</field>
        <field name="arch" type="xml">
            <tree string="Quy tắc chuyển trạng thái" editable="bottom">
                <field name="from_state_id" domain="from_state_domain" options="{'no_create': True}"/>
                <field name="from_state_domain" column_invisible="1"/>
                <field name="to_state_id" domain="to_state_domain" options="{'no_create': True}"/>
                <field name="to_state_domain" column_invisible="1"/>
                <field name="required_document"/>
                <field name="required_payment"/>
                <field name="note"/>
            </tree>
        </field>
    </record>

    <record id="action_exp_state_transition_rule" model="ir.actions.act_window">
        <field name="name">Quy tắc chuyển trạng thái</field>
        <field name="res_model">exp.state.transition.rule</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>