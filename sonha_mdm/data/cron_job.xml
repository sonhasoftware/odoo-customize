<odoo>
    <data noupdate="0">
        <record id="ir_cron_action_vector" model="ir.cron">
            <field name="name">Sinh vector cho mdm</field>
            <field name="model_id" ref="model_mdm_tong_hop"/>
            <field name="state">code</field>
            <field name="code">model.get_vector_mdm()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
        </record>

        <record id="ir_cron_action_vector_group" model="ir.cron">
            <field name="name">Sinh vector group cho mdm</field>
            <field name="model_id" ref="model_mdm_tong_hop"/>
            <field name="state">code</field>
            <field name="code">model.get_vector_group_mdm()</field>
            <field name="user_id" ref="base.user_root"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
        </record>
    </data>
</odoo>