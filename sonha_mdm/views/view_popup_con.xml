<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_mdm_tong_hop_line_tree" model="ir.ui.view">
        <field name="name">mdm.tong.hop.line.tree</field>
        <field name="model">mdm.tong.hop.line</field>
        <field name="arch" type="xml">
            <tree string="Bảng con hàng hóa" editable="bottom">
                <field name="ma_mdm"/>
                <field name="ma_dv"/>
                <field name="dvcs"/>
            </tree>
        </field>
    </record>

    <record id="action_mdm_tong_hop_line" model="ir.actions.act_window">
        <field name="name">Bảng tổng hợp con</field>
        <field name="res_model">mdm.tong.hop.line</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>