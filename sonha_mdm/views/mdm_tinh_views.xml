<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_mdm_tinh_tree" model="ir.ui.view">
        <field name="name">MDM tỉnh</field>
        <field name="model">mdm.tinh</field>
        <field name="arch" type="xml">
            <tree string="Tỉnh" editable="bottom">
                <field name="ma"/>
                <field name="ten"/>
            </tree>
        </field>
    </record>

    <record id="action_mdm_tinh" model="ir.actions.act_window">
        <field name="name">MDM tỉnh</field>
        <field name="res_model">mdm.tinh</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>