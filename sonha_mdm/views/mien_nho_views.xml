<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_mdm_mien_nho_tree" model="ir.ui.view">
        <field name="name">view.mdm.mien.nho.tree</field>
        <field name="model">mien.nho</field>
        <field name="arch" type="xml">
            <tree string="Miền nhỏ" editable="bottom">
                <field name="ma"/>
                <field name="ten"/>
            </tree>
        </field>
    </record>

    <record id="action_mien_nho" model="ir.actions.act_window">
        <field name="name">Miền nhỏ</field>
        <field name="res_model">mien.nho</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>