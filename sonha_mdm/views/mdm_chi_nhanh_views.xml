<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_mdm_chi_nhanh_tree" model="ir.ui.view">
        <field name="name">MDM chi nhánh</field>
        <field name="model">mdm.chi.nhanh</field>
        <field name="arch" type="xml">
            <tree string="Chi nhánh" editable="bottom">
                <field name="ma"/>
                <field name="ten"/>
            </tree>
        </field>
    </record>

    <record id="action_mdm_chi_nhanh" model="ir.actions.act_window">
        <field name="name">MDM chi nhánh</field>
        <field name="res_model">mdm.chi.nhanh</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>