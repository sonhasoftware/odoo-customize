<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_mdm_quoc_gia_tree" model="ir.ui.view">
        <field name="name">MDM Quốc gia</field>
        <field name="model">mdm.quoc.gia</field>
        <field name="arch" type="xml">
            <tree string="Quốc" editable="bottom">
                <field name="ma"/>
                <field name="ten"/>
            </tree>
        </field>
    </record>

    <record id="action_mdm_quoc_gia" model="ir.actions.act_window">
        <field name="name">MDM Quốc gia</field>
        <field name="res_model">mdm.quoc.gia</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>