<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_mdm_khu_vuc_tree" model="ir.ui.view">
        <field name="name">MDM khu vực</field>
        <field name="model">mdm.khu.vuc</field>
        <field name="arch" type="xml">
            <tree string="Khu vực" editable="bottom">
                <field name="ma"/>
                <field name="ten"/>
            </tree>
        </field>
    </record>

    <record id="action_mdm_khu_vuc" model="ir.actions.act_window">
        <field name="name">MDM khu vực</field>
        <field name="res_model">mdm.khu.vuc</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>