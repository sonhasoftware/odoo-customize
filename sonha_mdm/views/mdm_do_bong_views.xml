<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_mdm_do_bong_tree" model="ir.ui.view">
        <field name="name">MDM Độ bóng</field>
        <field name="model">mdm.do.bong</field>
        <field name="arch" type="xml">
            <tree string="Độ bóng" editable="bottom">
                <field name="ma"/>
                <field name="ten"/>
            </tree>
        </field>
    </record>

    <record id="action_mdm_do_bong" model="ir.actions.act_window">
        <field name="name">MDM Độ bóng</field>
        <field name="res_model">mdm.do.bong</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>