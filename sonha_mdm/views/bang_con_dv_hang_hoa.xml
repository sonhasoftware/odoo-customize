<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_bang_con_dv_hh_tree" model="ir.ui.view">
        <field name="name">Bảng con đơn vị hàng hóa</field>
        <field name="model">mdm.tong.hop.line</field>
        <field name="arch" type="xml">
            <tree string="Bảng con đơn vị hàng hóa" editable="bottom">
                <field name="ma_mdm"/>
                <field name="ma_dv"/>
                <field name="dvcs"/>
                <field name="ten"/>
                <field name="dvt"/>
                <field name="bom_sale"/>
            </tree>
        </field>
    </record>

    <record id="action_bang_con_dv_hh" model="ir.actions.act_window">
        <field name="name">Bảng con đơn vị hàng hóa</field>
        <field name="res_model">mdm.tong.hop.line</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>
