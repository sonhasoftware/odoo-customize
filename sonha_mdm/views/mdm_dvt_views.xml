<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_mdm_dvt_tree" model="ir.ui.view">
        <field name="name">MDM Đơn vị tính</field>
        <field name="model">mdm.dvt</field>
        <field name="arch" type="xml">
            <tree string="Đơn vị tính" editable="bottom">
                <field name="ma"/>
                <field name="ten"/>
            </tree>
        </field>
    </record>

    <record id="action_mdm_dvt" model="ir.actions.act_window">
        <field name="name">MDM Đơn vị tính</field>
        <field name="res_model">mdm.dvt</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>
