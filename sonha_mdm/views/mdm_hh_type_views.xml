<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_mdm_hh_type_tree" model="ir.ui.view">
        <field name="name">MDM Loại hàng hóa</field>
        <field name="model">mdm.hh.type</field>
        <field name="arch" type="xml">
            <tree string="Loại hàng hóa" editable="bottom">
                <field name="ma"/>
                <field name="ten"/>
            </tree>
        </field>
