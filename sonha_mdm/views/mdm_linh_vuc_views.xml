<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_mdm_linh_vuc_tree" model="ir.ui.view">
        <field name="name">MDM Lĩnh vực</field>
        <field name="model">mdm.linh.vuc</field>
        <field name="arch" type="xml">
            <tree string="Lĩnh vực" editable="bottom">
                <field name="ma"/>
                <field name="ten"/>
                <field name="key_map"/>
            </tree>
        </field>
    </record>

    <record id="action_mdm_linh_vuc" model="ir.actions.act_window">
        <field name="name">MDM Lĩnh vực</field>
        <field name="res_model">mdm.linh.vuc</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>