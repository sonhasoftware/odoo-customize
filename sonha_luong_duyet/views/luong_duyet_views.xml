<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_luong_duyet_form" model="ir.ui.view">
        <field name="name">luong.duyet.form</field>
        <field name="model">luong.duyet</field>
        <field name="arch" type="xml">
            <form string="Luồng duyệt">
                <sheet>
                    <group>
                    <field name="ten"/>
                    <field name="dvcs"/>
                    <field name="model_id"/>
                    </group>
                    <field name="step_ids">
                        <tree editable="bottom">
                            <field name="sequence"/>
                            <field name="phuong_thuc"/>
                            <field name="vai_tro" required="phuong_thuc == 'vt'"/>
                            <field name="ten_nguoi_duyet" widget="many2many_tags" readonly="1"/>
                        </tree>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_luong_duyet_tree" model="ir.ui.view">
        <field name="name">luong.duyet.tree</field>
        <field name="model">luong.duyet</field>
        <field name="arch" type="xml">
            <tree string="Luồng duyệt">
                <field name="ten"/>
                <field name="dvcs"/>
                <field name="model_id"/>
            </tree>
        </field>
    </record>


    <record id="action_luong_duyet" model="ir.actions.act_window">
            <field name="name">Luồng duyệt</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">luong.duyet</field>
            <field name="view_ids" eval="[(5, 0, 0),
                (0, 0, {'view_mode': 'tree', 'view_id': ref('view_luong_duyet_tree')}),
                (0, 0, {'view_mode': 'form', 'view_id': ref('view_luong_duyet_form')})]"/>
        </record>
</odoo>
