<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Security Category -->
        <record id="module_category_topic_chatbot" model="ir.module.category">
            <field name="name">Topic Chatbot</field>
            <field name="description">Access levels for Topic Chatbot module.</field>
            <field name="sequence">20</field>
        </record>

        <!-- Security Groups -->
        <record id="group_topic_chatbot_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_topic_chatbot"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_topic_chatbot_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_topic_chatbot"/>
            <field name="implied_ids" eval="[(4, ref('group_topic_chatbot_user'))]"/>
        </record>

        <!-- Auto-assign Topic Chatbot Admin to Odoo System Administrators -->
        <record id="base.group_system" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('group_topic_chatbot_admin'))]"/>
        </record>


        <!-- Record Rules: Topic -->
        <record id="rule_topic_chatbot_topic_read" model="ir.rule">
            <field name="name">Topic Chatbot Topic: Read Access (Public or Owner)</field>
            <field name="model_id" ref="model_topic_chatbot_topic"/>
            <field name="domain_force">['|', ('is_public', '=', True), ('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_topic_chatbot_topic_write" model="ir.rule">
            <field name="name">Topic Chatbot Topic: Write Access (Owner Only)</field>
            <field name="model_id" ref="model_topic_chatbot_topic"/>
            <field name="domain_force">[('create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_topic_chatbot_topic_admin" model="ir.rule">
            <field name="name">Topic Chatbot Topic: Admin Access</field>
            <field name="model_id" ref="model_topic_chatbot_topic"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_topic_chatbot_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record Rules: Document -->
        <record id="rule_topic_chatbot_document_read" model="ir.rule">
            <field name="name">Topic Chatbot Document: Read Access (Public or Owner)</field>
            <field name="model_id" ref="model_topic_chatbot_document"/>
            <field name="domain_force">['|', ('topic_id.is_public', '=', True), ('topic_id.create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_topic_chatbot_document_write" model="ir.rule">
            <field name="name">Topic Chatbot Document: Write Access (Owner Only)</field>
            <field name="model_id" ref="model_topic_chatbot_document"/>
            <field name="domain_force">[('topic_id.create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_topic_chatbot_document_admin" model="ir.rule">
            <field name="name">Topic Chatbot Document: Admin Access</field>
            <field name="model_id" ref="model_topic_chatbot_document"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_topic_chatbot_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record Rules: Chunk -->
        <record id="rule_topic_chatbot_chunk_read" model="ir.rule">
            <field name="name">Topic Chatbot Chunk: Read Access (Public or Owner)</field>
            <field name="model_id" ref="model_topic_chatbot_chunk"/>
            <field name="domain_force">['|', ('topic_id.is_public', '=', True), ('topic_id.create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="False"/>
            <field name="perm_create" eval="False"/>
            <field name="perm_unlink" eval="False"/>
        </record>

        <record id="rule_topic_chatbot_chunk_write" model="ir.rule">
            <field name="name">Topic Chatbot Chunk: Write Access (Owner Only)</field>
            <field name="model_id" ref="model_topic_chatbot_chunk"/>
            <field name="domain_force">[('topic_id.create_uid', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_topic_chatbot_chunk_admin" model="ir.rule">
            <field name="name">Topic Chatbot Chunk: Admin Access</field>
            <field name="model_id" ref="model_topic_chatbot_chunk"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_topic_chatbot_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <!-- Record Rules: Conversation -->
        <record id="rule_topic_chatbot_conversation_user" model="ir.rule">
            <field name="name">Topic Chatbot Conversation: User Access Only</field>
            <field name="model_id" ref="model_topic_chatbot_conversation"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_topic_chatbot_conversation_admin" model="ir.rule">
            <field name="name">Topic Chatbot Conversation: Admin Access Only Owner</field>
            <field name="model_id" ref="model_topic_chatbot_conversation"/>
            <field name="domain_force">[('user_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('group_topic_chatbot_admin'))]"/>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>
    </data>
</odoo>
