<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_ipr" model="ir.module.category">
        <field name="name">Internal Purchase Request</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_ipr_employee" model="res.groups">
        <field name="name">Employee</field>
        <field name="category_id" ref="module_category_ipr"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_ipr_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_ipr"/>
        <field name="implied_ids" eval="[(4, ref('sonha_ipr.group_ipr_employee'))]"/>
    </record>

    <record id="group_ipr_accountant" model="res.groups">
        <field name="name">Accountant</field>
        <field name="category_id" ref="module_category_ipr"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_ipr_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="module_category_ipr"/>
        <field name="implied_ids" eval="[(4, ref('sonha_ipr.group_ipr_manager')), (4, ref('sonha_ipr.group_ipr_accountant'))]"/>
    </record>

    <record id="rule_ipr_company" model="ir.rule">
        <field name="name">IPR multi-company rule</field>
        <field name="model_id" ref="model_ipr_request"/>
        <field name="domain_force">[('company_id', 'child_of', company_ids)]</field>
    </record>

    <record id="rule_ipr_line_company" model="ir.rule">
        <field name="name">IPR line multi-company rule</field>
        <field name="model_id" ref="model_ipr_request_line"/>
        <field name="domain_force">[('company_id', 'child_of', company_ids)]</field>
    </record>

    <record id="rule_ipr_employee_own" model="ir.rule">
        <field name="name">IPR Employee own requests</field>
        <field name="model_id" ref="model_ipr_request"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sonha_ipr.group_ipr_employee'))]"/>
    </record>

    <record id="rule_ipr_manager_department" model="ir.rule">
        <field name="name">IPR Manager department requests</field>
        <field name="model_id" ref="model_ipr_request"/>
        <field name="domain_force">['|', ('employee_id.user_id', '=', user.id), ('department_id', 'child_of', user.employee_id.department_id.ids)]</field>
        <field name="groups" eval="[(4, ref('sonha_ipr.group_ipr_manager'))]"/>
    </record>

    <record id="rule_ipr_accountant_approved" model="ir.rule">
        <field name="name">IPR Accountant approved requests</field>
        <field name="model_id" ref="model_ipr_request"/>
        <field name="domain_force">[('state', '=', 'approve')]</field>
        <field name="groups" eval="[(4, ref('sonha_ipr.group_ipr_accountant'))]"/>
    </record>

    <record id="rule_ipr_admin_all" model="ir.rule">
        <field name="name">IPR Admin all requests</field>
        <field name="model_id" ref="model_ipr_request"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('sonha_ipr.group_ipr_admin'))]"/>
    </record>

    <record id="rule_ipr_line_employee_own" model="ir.rule">
        <field name="name">IPR Line Employee own requests</field>
        <field name="model_id" ref="model_ipr_request_line"/>
        <field name="domain_force">[('request_id.employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sonha_ipr.group_ipr_employee'))]"/>
    </record>

    <record id="rule_ipr_line_manager_department" model="ir.rule">
        <field name="name">IPR Line Manager department requests</field>
        <field name="model_id" ref="model_ipr_request_line"/>
        <field name="domain_force">['|', ('request_id.employee_id.user_id', '=', user.id), ('request_id.department_id', 'child_of', user.employee_id.department_id.ids)]</field>
        <field name="groups" eval="[(4, ref('sonha_ipr.group_ipr_manager'))]"/>
    </record>

    <record id="rule_ipr_line_accountant_approved" model="ir.rule">
        <field name="name">IPR Line Accountant approved requests</field>
        <field name="model_id" ref="model_ipr_request_line"/>
        <field name="domain_force">[('request_id.state', '=', 'approve')]</field>
        <field name="groups" eval="[(4, ref('sonha_ipr.group_ipr_accountant'))]"/>
    </record>

    <record id="rule_ipr_line_admin_all" model="ir.rule">
        <field name="name">IPR Line Admin all requests</field>
        <field name="model_id" ref="model_ipr_request_line"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('sonha_ipr.group_ipr_admin'))]"/>
    </record>
</odoo>
