<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ipr_approval_wizard_form" model="ir.ui.view">
        <field name="name">ipr.approval.wizard.form</field>
        <field name="model">ipr.approval.wizard</field>
        <field name="arch" type="xml">
            <form string="Approve Purchase Request">
                <group>
                    <field name="request_id"/>
                    <field name="approver_id"/>
                    <field name="note" placeholder="Nhập ghi chú duyệt..."/>
                </group>
                <footer>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

