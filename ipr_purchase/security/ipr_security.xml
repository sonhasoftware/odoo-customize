<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ─── Category ─── -->
    <record id="module_ipr_category" model="ir.module.category">
        <field name="name">Internal Purchase Request</field>
        <field name="sequence">50</field>
    </record>

    <!-- ─── Groups ─── -->
    <record id="group_ipr_employee" model="res.groups">
        <field name="name">Nhân viên</field>
        <field name="category_id" ref="module_ipr_category"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_ipr_manager" model="res.groups">
        <field name="name">Trưởng phòng</field>
        <field name="category_id" ref="module_ipr_category"/>
        <field name="implied_ids" eval="[(4, ref('group_ipr_employee'))]"/>
    </record>

    <record id="group_ipr_accountant" model="res.groups">
        <field name="name">Kế toán</field>
        <field name="category_id" ref="module_ipr_category"/>
        <field name="implied_ids" eval="[(4, ref('group_ipr_employee'))]"/>
    </record>

    <record id="group_ipr_admin" model="res.groups">
        <field name="name">Admin</field>
        <field name="category_id" ref="module_ipr_category"/>
        <field name="implied_ids" eval="[(4, ref('group_ipr_manager')), (4, ref('group_ipr_accountant'))]"/>
    </record>

    <!-- ─── Record Rules ─── -->

    <!-- Employee: chỉ thấy request của chính mình -->
    <record id="ipr_request_rule_employee" model="ir.rule">
        <field name="name">IPR: Employee xem request của mình</field>
        <field name="model_id" ref="model_ipr_request"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_ipr_employee'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <!-- Manager: thấy request trong phòng ban của mình -->
    <record id="ipr_request_rule_manager" model="ir.rule">
        <field name="name">IPR: Manager xem request trong phòng ban</field>
        <field name="model_id" ref="model_ipr_request"/>
        <field name="domain_force">[
            '|',
            ('employee_id.user_id', '=', user.id),
            ('department_id.manager_id.user_id', '=', user.id)
        ]</field>
        <field name="groups" eval="[(4, ref('group_ipr_manager'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Accountant: chỉ thấy request đã approved -->
    <record id="ipr_request_rule_accountant" model="ir.rule">
        <field name="name">IPR: Kế toán xem request đã duyệt</field>
        <field name="model_id" ref="model_ipr_request"/>
        <field name="domain_force">[('state', '=', 'approve')]</field>
        <field name="groups" eval="[(4, ref('group_ipr_accountant'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Multi-company rule: chỉ thấy data thuộc company của mình hoặc company con -->
    <record id="ipr_request_rule_multicompany" model="ir.rule">
        <field name="name">IPR: Multi-company filter</field>
        <field name="model_id" ref="model_ipr_request"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="global" eval="True"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>
