<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_import_vat_tu_di_duong_wizard_form" model="ir.ui.view">
        <field name="name">import.vat.tu.di.duong.wizard.form</field>
        <field name="model">import.vat.tu.di.duong.wizard</field>
        <field name="arch" type="xml">
            <form string="Import vật tư đi đường">
                <group>
                    <field name="file_data" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                </group>
                <footer>
                    <button name="action_import" type="object" string="Import" class="btn-primary"/>
                    <button name="action_download_template" type="object" string="Tải template"/>
                    <button string="Hủy" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
