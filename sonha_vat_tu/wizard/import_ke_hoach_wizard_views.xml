<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_ke_hoach_wizard_form" model="ir.ui.view">
        <field name="name">import.ke.hoach.wizard.form</field>
        <field name="model">import.ke.hoach.wizard</field>
        <field name="arch" type="xml">
            <form string="Import kế hoạch">
                <sheet>
                    <group>
                        <group>
                            <field name="period_id" readonly="1" required="1"/>
                            <field name="import_type" invisible="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="file_data" filename="file_name" required="1"/>
                        <field name="file_name" invisible="1"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_import" type="object"
                            string="Import" class="btn-primary"/>
                    <button string="Huỷ" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
