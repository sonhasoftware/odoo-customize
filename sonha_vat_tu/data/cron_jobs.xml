<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron Job: Chạy Procedure tính lại BOM Chuỗi cung ứng -->
        <record id="cron_rebuild_bom_chuoi_cung_ung" model="ir.cron">
            <field name="name">Vật tư: Tự động tính toán lại BOM Chuỗi Cung Ứng</field>
            <field name="model_id" ref="model_ke_hoach_vat_tu"/>
            <field name="state">code</field>
            <field name="code">env.cr.execute("CALL public.fn_bom_chuoi_cung_ung()")</field>
            <field name="interval_type">days</field>
            <field name="interval_number">1</field>
            <field name="nextcall" eval="DateTime.now().replace(hour=21, minute=0, second=0).strftime('%Y-%m-%d %H:%M:%S')"/>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
