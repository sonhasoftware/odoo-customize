<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dinh_muc_tree" model="ir.ui.view">
        <field name="name">dinh.muc.tree</field>
        <field name="model">dinh.muc</field>
        <field name="arch" type="xml">
            <tree string="B2 - Định mức kỳ" create="0">
                <field name="period_id" required="1"/>
                <field name="company_id" required="1"/>
                <field name="ma_sap"/>
                <field name="ten_sap"/>
                <field name="ma_tp"/>
                <field name="ma_nvl"/>
                <field name="month_key" required="1"/>
                <field name="qty" string="Số lượng thô"/>
            </tree>
        </field>
    </record>

    <record id="action_dinh_muc" model="ir.actions.act_window">
        <field name="name">B2 - Định mức kỳ</field>
        <field name="res_model">dinh.muc</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_dinh_muc_tree"/>
    </record>

</odoo>
