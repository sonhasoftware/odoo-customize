<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_dinh_muc_tree" model="ir.ui.view">
        <field name="name">dinh.muc.tree</field>
        <field name="model">dinh.muc</field>
        <field name="arch" type="xml">
            <tree string="Định mức kỳ" create="0" class="sh_free_width_tree">
                <field name="ma_sap"/>
                <field name="ten_sap"/>
                <field name="ma_tp" column_invisible="True"/>
                <field name="ma_nvl"/>
                <field name="qty_t0" sum="T0"/>
                <field name="qty_t1" sum="T1"/>
                <field name="qty_t2" sum="T2"/>
                <field name="qty_t3" sum="T3"/>
            </tree>
        </field>
    </record>

    <record id="view_dinh_muc_search" model="ir.ui.view">
        <field name="name">dinh.muc.search</field>
        <field name="model">dinh.muc</field>
        <field name="arch" type="xml">
            <search>
                <field name="period_id"/>
                <field name="company_id"/>
                <field name="ma_sap"/>
                <field name="ten_sap"/>
                <field name="ma_tp"/>
                <field name="ma_nvl"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_period" string="Kỳ" context="{'group_by': 'period_id'}"/>
                    <filter name="group_company" string="Công ty" context="{'group_by': 'company_id'}"/>
                    <filter name="group_sap" string="Mã SAP" context="{'group_by': 'ma_sap'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_dinh_muc" model="ir.actions.act_window">
        <field name="name">Định mức kỳ</field>
        <field name="res_model">dinh.muc</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_dinh_muc_tree"/>
    </record>

</odoo>
