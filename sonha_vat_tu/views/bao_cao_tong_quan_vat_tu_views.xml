<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_bao_cao_tong_quan_vat_tu_tree" model="ir.ui.view">
        <field name="name">bao.cao.tong.quan.vat.tu.tree</field>
        <field name="model">bao.cao.tong.quan.vat.tu</field>
        <field name="arch" type="xml">
            <tree string="Báo cáo tổng quan vật tư" create="false" edit="false" delete="false"
                  decoration-danger="qty_chenh_lech &lt; 0"
                  decoration-success="qty_chenh_lech &gt; 0">
                <field name="company_id" string="Đơn vị" context="{'vat_tu_company_code_display': True}"/>
                <field name="code" string="Số chứng từ"/>
                <field name="period_month" string="Tháng bắt đầu"/>
                <field name="ma_nvl" string="Mã NVL"/>
                <field name="ten_nvl" string="Tên NVL"/>
                <field name="qty_kinh_doanh" sum="Kinh doanh"/>
                <field name="qty_san_xuat" sum="Sản xuất"/>
                <field name="qty_chenh_lech" sum="Chênh lệch"/>
            </tree>
        </field>
    </record>

    <record id="view_bao_cao_tong_quan_vat_tu_search" model="ir.ui.view">
        <field name="name">bao.cao.tong.quan.vat.tu.search</field>
        <field name="model">bao.cao.tong.quan.vat.tu</field>
        <field name="arch" type="xml">
            <search>
                <field name="company_id" string="Đơn vị" context="{'vat_tu_company_code_display': True}"/>
                <field name="code" string="Số chứng từ"/>
                <field name="period_month" string="Tháng bắt đầu"/>
                <field name="ma_nvl" string="Mã NVL"/>
                <field name="ten_nvl" string="Tên NVL"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_company" string="Đơn vị" context="{'group_by': 'company_id'}"/>
                    <filter name="group_code" string="Số chứng từ" context="{'group_by': 'code'}"/>
                    <filter name="group_period_month" string="Tháng bắt đầu" context="{'group_by': 'period_month'}"/>
                    <filter name="group_ma_nvl" string="Mã NVL" context="{'group_by': 'ma_nvl'}"/>
                    <filter name="group_ten_nvl" string="Tên NVL" context="{'group_by': 'ten_nvl'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bao_cao_tong_quan_vat_tu" model="ir.actions.act_window">
        <field name="name">Báo cáo tổng quan vật tư</field>
        <field name="res_model">bao.cao.tong.quan.vat.tu</field>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_bao_cao_tong_quan_vat_tu_tree"/>
        <field name="search_view_id" ref="view_bao_cao_tong_quan_vat_tu_search"/>
        <field name="context">{'vat_tu_company_code_display': True}</field>
    </record>

</odoo>
