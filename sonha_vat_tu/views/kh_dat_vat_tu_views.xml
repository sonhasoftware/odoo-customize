<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_kh_dat_vat_tu_tree" model="ir.ui.view">
        <field name="name">kh.dat.vat.tu.tree</field>
        <field name="model">kh.dat.vat.tu</field>
        <field name="arch" type="xml">
            <tree string="Kế hoạch đặt vật tư" editable="bottom" class="sh_free_width_tree">
                <field name="period_id" required="1"/>
                <field name="company_id" required="1"/>
                <field name="month_key" required="1"/>
                <field name="ma_sap" required="1"/>
                <field name="ma_effect"/>
                <field name="ma_cuon"/>
                <field name="don_vi_tinh"/>
                <field name="tong_ton_nvl_sl" string="Tổng tồn nguyên vật liệu" sum="Tổng tồn nguyên vật liệu"/>
                <field name="tong_hang_di_duong_sl" string="Tổng hàng đi đường" sum="Tổng đi đường"/>
                <field name="tong_sl_vt_can_dung" string="Tổng số lượng vật tư cần dùng" sum="Tổng cần dùng"/>
                <field name="sl_du_tru_toi_thieu" string="Số lượng dự trữ tối thiểu" sum="Tổng dự trữ"/>
                <field name="sl_can_mua_theo_moq" string="Số lượng cần mua theo MOQ" sum="Tổng MOQ"/>
                <field name="sl_dat_mua_de_xuat" string="Số lượng đặt mua đề xuất" sum="Tổng đề xuất"/>
                <field name="sl_dat_mua_chot" string="Số lượng đặt mua chốt" sum="Tổng chốt"/>
                <field name="sl_ton_kho" string="Số lượng tồn kho" sum="Tổng tồn kho"/>
                <field name="so_ngay_vong_quay_ton" string="Số ngày vòng quay"/>
                <field name="don_gia_ton_kho" string="Đơn giá tồn kho"/>
                <field name="gia_tri_ton_kho" string="Giá trị tồn kho" sum="Tổng giá trị tồn kho"/>
                <field name="ghi_chu"/>
            </tree>
        </field>
    </record>

    <record id="view_kh_dat_vat_tu_form" model="ir.ui.view">
        <field name="name">kh.dat.vat.tu.form</field>
        <field name="model">kh.dat.vat.tu</field>
        <field name="arch" type="xml">
            <form string="Kế hoạch đặt vật tư">
                <sheet>
                    <group>
                        <group>
                            <field name="period_id" required="1"/>
                            <field name="company_id" required="1"/>
                            <field name="month_key" required="1"/>
                            <field name="ma_sap" required="1"/>
                            <field name="ma_effect"/>
                        </group>
                        <group>
                            <field name="ma_cuon"/>
                            <field name="don_vi_tinh"/>
                            <field name="ghi_chu"/>
                        </group>
                    </group>
                    <group string="Số liệu B5">
                        <group>
                            <field name="tong_ton_nvl_sl"/>
                            <field name="tong_hang_di_duong_sl"/>
                            <field name="tong_sl_vt_can_dung"/>
                            <field name="sl_du_tru_toi_thieu"/>
                            <field name="sl_can_mua_theo_moq"/>
                        </group>
                        <group>
                            <field name="sl_dat_mua_de_xuat" readonly="1"/>
                            <field name="sl_dat_mua_chot" readonly="1"/>
                            <field name="sl_ton_kho" readonly="1"/>
                            <field name="so_ngay_vong_quay_ton" readonly="1"/>
                            <field name="don_gia_ton_kho"/>
                            <field name="gia_tri_ton_kho" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_kh_dat_vat_tu_search" model="ir.ui.view">
        <field name="name">kh.dat.vat.tu.search</field>
        <field name="model">kh.dat.vat.tu</field>
        <field name="arch" type="xml">
            <search>
                <field name="period_id"/>
                <field name="ma_sap"/>
                <field name="month_key"/>
                <field name="company_id"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="g_period" string="Kỳ" context="{'group_by': 'period_id'}"/>
                    <filter name="g_company" string="Đơn vị" context="{'group_by': 'company_id'}"/>
                    <filter name="g_month" string="Tháng" context="{'group_by': 'month_key'}"/>
                    <filter name="g_sap" string="Mã SAP" context="{'group_by': 'ma_sap'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_kh_dat_vat_tu" model="ir.actions.act_window">
        <field name="name">Kế hoạch đặt vật tư</field>
        <field name="res_model">kh.dat.vat.tu</field>
        <field name="view_mode">tree,form</field>
        <field name="views" eval="[(ref('view_kh_dat_vat_tu_tree'), 'tree'), (ref('view_kh_dat_vat_tu_form'), 'form')]"/>
    </record>

</odoo>
