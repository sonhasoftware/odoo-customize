<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vat_tu_di_duong_tree" model="ir.ui.view">
        <field name="name">vat.tu.di.duong.tree</field>
        <field name="model">vat.tu.di.duong</field>
        <field name="arch" type="xml">
            <tree string="Vật tư đi đường" editable="bottom">
                <field name="company_id"/>
                <field name="ma_sap" required="1"/>
                <field name="month_key" required="1"/>
                <field name="so_luong" sum="SL"/>
            </tree>
        </field>
    </record>

    <record id="view_vat_tu_di_duong_search" model="ir.ui.view">
        <field name="name">vat.tu.di.duong.search</field>
        <field name="model">vat.tu.di.duong</field>
        <field name="arch" type="xml">
            <search>
                <field name="company_id"/>
                <field name="ma_sap"/>
                <field name="month_key"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_company" string="Đơn vị"
                            context="{'group_by': 'company_id'}"/>
                    <filter name="group_month" string="Tháng"
                            context="{'group_by': 'month_key'}"/>
                    <filter name="group_sap" string="Mã SAP"
                            context="{'group_by': 'ma_sap'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_vat_tu_di_duong" model="ir.actions.act_window">
        <field name="name">Vật tư đi đường</field>
        <field name="res_model">vat.tu.di.duong</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="view_vat_tu_di_duong_search"/>
    </record>

</odoo>
