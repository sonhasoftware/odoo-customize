<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ma_hang_tree" model="ir.ui.view">
        <field name="name">ma.hang.tree</field>
        <field name="model">ma.hang</field>
        <field name="arch" type="xml">
            <tree create="false" edit="false" delete="false">
                <field name="ma_mdm" string="Mã MDM"/>
                <field name="ma_sap" string="Mã đơn vị"/>
                <field name="ten_hang" string="Tên hàng hóa"/>
                <field name="don_vi_tinh_id" string="Đơn vị tính"/>
                <field name="company_id" string="ĐVCS" context="{'vat_tu_company_code_display': True}"/>
                <field name="bom_sale_id" column_invisible="True"/>
                <field name="nganh_hang" string="Ngành hàng"/>
            </tree>
        </field>
    </record>

    <record id="view_ma_hang_search" model="ir.ui.view">
        <field name="name">ma.hang.search</field>
        <field name="model">ma.hang</field>
        <field name="arch" type="xml">
            <search>
                <field name="ma_mdm"/>
                <field name="ma_sap"/>
                <field name="ten_hang"/>
                <field name="company_id" context="{'vat_tu_company_code_display': True}"/>
                <field name="nganh_hang"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_company" string="ĐVCS" context="{'group_by': 'company_id', 'vat_tu_company_code_display': True}"/>
                    <filter name="group_nganh" string="Ngành hàng" context="{'group_by': 'nganh_hang'}"/>
                    <filter name="group_dvt" string="Đơn vị tính" context="{'group_by': 'don_vi_tinh_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ma_hang" model="ir.actions.act_window">
        <field name="name">Mã hàng</field>
        <field name="res_model">ma.hang</field>
        <field name="view_mode">tree</field>
        <field name="context">{'vat_tu_company_code_display': True}</field>
    </record>
</odoo>
