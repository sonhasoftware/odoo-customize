                            <field name="ve_du_kien_t1" readonly="1"/>
                            <field name="ve_du_kien_t2" readonly="1"/>
                            <field name="ve_du_kien_t3" readonly="1"/>

                            <field name="vt_can_dung_t0" readonly="1"/>
                            <field name="vt_can_dung_t1" readonly="1"/>
                            <field name="vt_can_dung_t2" readonly="1"/>
                            <field name="vt_can_dung_t3" readonly="1"/>

                            <field name="ton_cuoi_t0" readonly="1"/>
                            <field name="ton_cuoi_t1" readonly="1"/>
                            <field name="ton_cuoi_t2" readonly="1"/>
