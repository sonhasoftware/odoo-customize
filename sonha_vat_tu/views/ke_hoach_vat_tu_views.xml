<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ke_hoach_vat_tu_tree" model="ir.ui.view">
        <field name="name">ke.hoach.vat.tu.tree</field>
        <field name="model">ke.hoach.vat.tu</field>
        <field name="arch" type="xml">
            <tree string="Kế hoạch vật tư">
                <field name="code"/>
                <field name="period_month" required="1"/>
                <field name="company_id" string="Đơn vị" context="{'vat_tu_company_code_display': True}"/>
            </tree>
        </field>
    </record>

    <record id="view_ke_hoach_vat_tu_form_b1" model="ir.ui.view">
        <field name="name">ke.hoach.vat.tu.form.b1</field>
        <field name="model">ke.hoach.vat.tu</field>
        <field name="arch" type="xml">
            <form string="Kế hoạch sản xuất">
                <header>
                    <button name="action_generate_b2" type="object" string="Sinh định mức kỳ"
                            class="btn-primary"
                            groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu"
                            invisible="state != 'ke_hoach'"/>
                    <field name="state" widget="statusbar" statusbar_visible="ke_hoach,dinh_muc,tinh_toan,tong_hop,dat_hang"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_step_b2" type="object" class="oe_stat_button" icon="fa-arrow-right"
                                groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu">
                            <field name="dinh_muc_count" string="Định mức kỳ" widget="statinfo"/>
                        </button>
                        <button name="action_open_step_b3" type="object" class="oe_stat_button" icon="fa-calculator"
                                groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu">
                            <field name="tinh_toan_vat_tu_count" string="Tính toán vật tư" widget="statinfo"/>
                        </button>
                        <button name="action_open_step_b4" type="object" class="oe_stat_button" icon="fa-cubes"
                                groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu">
                            <field name="tong_hop_vat_tu_count" string="Tổng hợp vật tư cần sản xuất" widget="statinfo"/>
                        </button>
                        <button name="action_open_step_b5" type="object" class="oe_stat_button" icon="fa-shopping-cart"
                                groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu">
                            <field name="kh_dat_vat_tu_count" string="Kế hoạch đặt vật tư" widget="statinfo"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="code"/>
                        <h1><field name="code"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="period_month" required="1"/>
                            <field name="company_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </group>
                    <div style="display:flex; gap:8px; align-items:center; flex-wrap:wrap; margin-bottom:8px;">
                        <button name="action_download_b1_template" type="object" string="Tải template kinh doanh"
                                class="btn btn-secondary" icon="fa-download"
                                groups="sonha_vat_tu.group_ban_cung_ung_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu"
                                invisible="state != 'ke_hoach'"/>
                        <button name="action_open_import_kinh_doanh_wizard" type="object" string="Import kế hoạch kinh doanh"
                                class="btn btn-primary" icon="fa-upload"
                                groups="sonha_vat_tu.group_ban_cung_ung_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu"
                                invisible="state != 'ke_hoach'"/>
                        <button name="action_export_san_xuat" type="object" string="Export kế hoạch sản xuất"
                                class="btn btn-secondary" icon="fa-download"
                                groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu"
                                invisible="state != 'ke_hoach'"/>
                        <button name="action_open_import_san_xuat_wizard" type="object" string="Import kế hoạch sản xuất"
                                class="btn btn-primary" icon="fa-upload"
                                groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu"
                                invisible="state != 'ke_hoach'"/>
                    </div>
                    <notebook>
                        <page string="Kế hoạch kinh doanh">
                            <field name="ke_hoach_kinh_doanh_ids" context="{'default_period_id': id}"
                                   groups="sonha_vat_tu.group_ban_cung_ung_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu"
                                   readonly="state != 'ke_hoach'">
                                <tree editable="bottom">
                                    <field name="nganh_hang" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="dong_hang" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="ma_hang_id" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="ma_sap" readonly="1" required="1"/>
                                    <field name="month_key" required="1"/>
                                    <field name="qty" sum="SL kinh doanh"/>
                                </tree>
                            </field>
                            <field name="ke_hoach_kinh_doanh_ids" readonly="1"
                                   groups="sonha_vat_tu.group_bo_phan_vat_tu,!sonha_vat_tu.group_ban_cung_ung_vat_tu,!sonha_vat_tu.group_truong_bo_phan_vat_tu">
                                <tree editable="bottom">
                                    <field name="nganh_hang"/>
                                    <field name="dong_hang"/>
                                    <field name="ma_hang_id"/>
                                    <field name="ma_sap"/>
                                    <field name="month_key"/>
                                    <field name="qty" sum="SL kinh doanh"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Kế hoạch sản xuất">
                            <field name="ke_hoach_san_xuat_ids" readonly="1"
                                   groups="sonha_vat_tu.group_ban_cung_ung_vat_tu,!sonha_vat_tu.group_bo_phan_vat_tu,!sonha_vat_tu.group_truong_bo_phan_vat_tu">
                                <tree editable="bottom">
                                    <field name="nganh_hang"/>
                                    <field name="dong_hang"/>
                                    <field name="ma_hang_id"/>
                                    <field name="ma_sap"/>
                                    <field name="month_key"/>
                                    <field name="company_id" column_invisible="True"/>
                                    <field name="qty" sum="SL sản xuất"/>
                                </tree>
                            </field>
                            <field name="ke_hoach_san_xuat_ids" context="{'default_period_id': id}"
                                   groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu"
                                   readonly="state != 'ke_hoach'">
                                <tree editable="bottom">
                                    <field name="nganh_hang" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="dong_hang" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="ma_hang_id" readonly="1" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="ma_sap" readonly="1" required="1"/>
                                    <field name="month_key" readonly="1" required="1"/>
                                    <field name="company_id" column_invisible="True"/>
                                    <field name="qty" sum="SL sản xuất"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_ke_hoach_vat_tu_form_b2" model="ir.ui.view">
        <field name="name">ke.hoach.vat.tu.form.b2</field>
        <field name="model">ke.hoach.vat.tu</field>
        <field name="arch" type="xml">
            <form string="Định mức kỳ">
                <header>
                    <button name="action_compute_b3" type="object" string="Tính toán vật tư"
                            class="btn-primary"
                            groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu"
                            invisible="state != 'dinh_muc'"/>
                    <field name="state" widget="statusbar" statusbar_visible="ke_hoach,dinh_muc,tinh_toan,tong_hop,dat_hang"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_step_b1" type="object" class="oe_stat_button" icon="fa-arrow-left"
                                groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu">
                            <field name="ke_hoach_san_xuat_count" string="Kế hoạch sản xuất" widget="statinfo"/>
                        </button>
                        <button name="action_open_step_b3" type="object" class="oe_stat_button" icon="fa-arrow-right"
                                groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu">
                            <field name="tinh_toan_vat_tu_count" string="Tính toán vật tư" widget="statinfo"/>
                        </button>
                    </div>
                    <group col="3">
                        <group>
                            <field name="code" string="Số chứng từ"/>
                        </group>
                        <group>
                            <field name="period_month" readonly="1"/>
                        </group>
                        <group>
                            <field name="company_id" string="Đơn vị" readonly="1"
                                   context="{'vat_tu_company_code_display': True}"/>
                        </group>
                    </group>
                    <field name="dinh_muc_ids" readonly="1">
                        <tree editable="bottom" create="false" delete="false">
                            <field name="ma_sap" readonly="1"/>
                            <field name="ten_sap" readonly="1"/>
                            <field name="ma_tp" string="Mã TP" readonly="1"/>
                            <field name="ten_tp" string="Tên TP" readonly="1"/>
                            <field name="ma_nvl" string="Mã NVL" readonly="1"/>
                            <field name="ten_nvl" string="Tên NVL" readonly="1"/>
                            <field name="month_key" required="1" readonly="1"/>
                            <field name="qty" string="Số lượng thô" readonly="1"/>
                        </tree>
                    </field>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_ke_hoach_vat_tu_form_b3" model="ir.ui.view">
        <field name="name">ke.hoach.vat.tu.form.b3</field>
        <field name="model">ke.hoach.vat.tu</field>
        <field name="arch" type="xml">
            <form string="Tính toán vật tư">
                <header>
                    <button name="action_compute_b4" type="object" string="Tổng hợp vật tư cần sản xuất"
                            class="btn-primary"
                            groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu"
                            invisible="state != 'tinh_toan'"/>
                    <field name="state" widget="statusbar" statusbar_visible="ke_hoach,dinh_muc,tinh_toan,tong_hop,dat_hang"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_step_b2" type="object" class="oe_stat_button" icon="fa-arrow-left"
                                groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu">
                            <field name="dinh_muc_count" string="Định mức kỳ" widget="statinfo"/>
                        </button>
                        <button name="action_open_step_b4" type="object" class="oe_stat_button" icon="fa-arrow-right"
                                groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu">
                            <field name="tong_hop_vat_tu_count" string="Tổng hợp vật tư cần sản xuất" widget="statinfo"/>
                        </button>
                    </div>
                    <group col="3">
                        <group>
                            <field name="code" string="Số chứng từ"/>
                        </group>
                        <group>
                            <field name="period_month" readonly="1"/>
                        </group>
                        <group>
                            <field name="company_id" string="Đơn vị" readonly="1"
                                   context="{'vat_tu_company_code_display': True}"/>
                        </group>
                    </group>
                    <field name="tinh_toan_vat_tu_ids">
                        <tree editable="bottom" create="false" delete="false" class="sh_free_width_tree">
                            <field name="ma_sap" required="1" readonly="1"/>
                            <field name="ten_sap" readonly="1"/>
                            <field name="ma_vat_tu" string="Mã NVL" readonly="1"/>
                            <field name="ten_vat_tu" string="Tên NVL" readonly="1"/>
                            <field name="don_vi_tinh" readonly="1"/>
                            <field name="month_key" required="1" readonly="1"/>
                            <field name="sl_dinh_muc" readonly="1"/>
                            <field name="qty" column_invisible="True" readonly="1"/>
                        </tree>
                    </field>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_ke_hoach_vat_tu_form_b4" model="ir.ui.view">
        <field name="name">ke.hoach.vat.tu.form.b4</field>
        <field name="model">ke.hoach.vat.tu</field>
        <field name="arch" type="xml">
            <form string="Tổng hợp vật tư cần sản xuất">
                <header>
                    <button name="action_compute_b5" type="object" string="Kế hoạch đặt vật tư"
                            class="btn-primary"
                            groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu"
                            invisible="state != 'tong_hop'"/>
                    <field name="state" widget="statusbar" statusbar_visible="ke_hoach,dinh_muc,tinh_toan,tong_hop,dat_hang"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_step_b3" type="object" class="oe_stat_button" icon="fa-arrow-left"
                                groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu">
                            <field name="tinh_toan_vat_tu_count" string="Tính toán vật tư" widget="statinfo"/>
                        </button>
                        <button name="action_open_step_b5" type="object" class="oe_stat_button" icon="fa-arrow-right"
                                groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu">
                            <field name="kh_dat_vat_tu_count" string="Kế hoạch đặt vật tư" widget="statinfo"/>
                        </button>
                    </div>
                    <group col="3">
                        <group>
                            <field name="code" string="Số chứng từ"/>
                        </group>
                        <group>
                            <field name="period_month" readonly="1"/>
                        </group>
                        <group>
                            <field name="company_id" string="Đơn vị" readonly="1"
                                   context="{'vat_tu_company_code_display': True}"/>
                        </group>
                    </group>
                    <field name="tong_hop_vat_tu_ids">
                        <tree editable="bottom" create="false" delete="false" class="sh_free_width_tree">
                            <field name="ma_sap" string="Mã NVL" required="1" readonly="1"/>
                            <field name="ten_nvl" string="Tên NVL" readonly="1"/>
                            <field name="chung_loai" string="Chủng loại"/>
                            <field name="don_vi_tinh" readonly="1"/>
                            <field name="month_key" required="1" readonly="1"/>
                            <field name="ton_dau" readonly="1"/>
                            <field name="ve_du_kien" readonly="1"/>
                            <field name="vt_can_dung" readonly="1"/>
                            <field name="ton_cuoi" readonly="1"/>
                            <field name="so_luong_du_phong" readonly="1"/>
                            <field name="so_luong_thieu" readonly="1"/>
