    <record id="view_ke_hoach_vat_tu_form_b4" model="ir.ui.view">
        <field name="name">ke.hoach.vat.tu.form.b4</field>
        <field name="model">ke.hoach.vat.tu</field>
        <field name="arch" type="xml">
            <form string="Tổng hợp vật tư cần sản xuất">
                <header>
                    <button name="action_compute_b5" type="object" string="Kế hoạch đặt vật tư"
