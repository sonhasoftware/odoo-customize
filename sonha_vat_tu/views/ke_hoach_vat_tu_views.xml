    <record id="view_ke_hoach_vat_tu_form_b5" model="ir.ui.view">
        <field name="name">ke.hoach.vat.tu.form.b5</field>
        <field name="model">ke.hoach.vat.tu</field>
        <field name="arch" type="xml">
            <form string="Kế hoạch đặt vật tư">
                <header>
                    <button name="action_submit_approval" type="object" string="Duyệt"
                            class="btn-primary"
                            groups="sonha_vat_tu.group_bo_phan_vat_tu,sonha_vat_tu.group_truong_bo_phan_vat_tu"
                            invisible="state != 'dat_hang' or approval_state != 'draft'"/>
                    <button name="action_approve_material_plan" type="object" string="Duyệt"
                            class="btn-primary"
                            invisible="not can_approve"/>
                    <field name="state" widget="statusbar" statusbar_visible="ke_hoach,dinh_muc,tinh_toan,tong_hop,dat_hang"/>
                </header>
                <sheet>
                    <field name="can_approve" invisible="1"/>
                    <field name="approval_state" invisible="1"/>
                    <field name="approval_company_id" invisible="1"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_step_b1" type="object" class="oe_stat_button" icon="fa-arrow-left">
                            <field name="ke_hoach_san_xuat_count" string="Kế hoạch vật tư" widget="statinfo"/>
                        </button>
                        <button name="action_open_step_b2" type="object" class="oe_stat_button" icon="fa-arrow-right">
                            <field name="dinh_muc_count" string="Định mức kỳ" widget="statinfo"/>
                        </button>
                        <button name="action_open_step_b3" type="object" class="oe_stat_button" icon="fa-calculator">
                            <field name="tinh_toan_vat_tu_count" string="Tính toán vật tư" widget="statinfo"/>
                        </button>
                        <button name="action_open_step_b4" type="object" class="oe_stat_button" icon="fa-cubes">
                            <field name="tong_hop_vat_tu_count" string="Tổng hợp vật tư cần sản xuất" widget="statinfo"/>
                        </button>
                    </div>
                    <group col="2">
                        <group>
                            <field name="code" string="Số chứng từ"/>
                        </group>
                        <group>
                            <field name="period_month" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Kế hoạch đặt vật tư">
                            <field name="kh_dat_vat_tu_ids" widget="vat_tu_merged_b5_one2many">
                                <tree editable="bottom" create="false" delete="false" class="sh_free_width_tree">
                                    <field name="ma_sap" string="Mã NVL" required="1" readonly="1"/>
                                    <field name="ten_nvl" string="Tên NVL" readonly="1"/>
                                    <field name="chung_loai" string="Chủng loại" readonly="1"/>
                                    <field name="don_vi_tinh" readonly="1"/>
                                    <field name="currency_id" column_invisible="True"/>

                                    <field name="don_gia_ton_kho" string="Đơn giá tồn kho" widget="monetary" readonly="1"/>
                                    <field name="tong_ton_nvl_sl" string="Tồn NVL đầu kỳ" readonly="1"/>
                                    <field name="gia_tri_ton_nvl_dau_ky" string="Giá trị tồn NVL" readonly="1" widget="monetary"/>

                                    <field name="tong_sl_vt_can_dung_t0" readonly="1"/>
                                    <field name="tong_sl_vt_can_dung_t1" readonly="1"/>
                                    <field name="tong_sl_vt_can_dung_t2" readonly="1"/>
                                    <field name="tong_sl_vt_can_dung_t3" readonly="1"/>
                                    <field name="tong_vt_can_dung" string="Tổng cần dùng" readonly="1"/>

                                    <field name="tong_hang_di_duong_sl_t0" readonly="1"/>
                                    <field name="tong_hang_di_duong_sl_t1" readonly="1"/>
                                    <field name="tong_hang_di_duong_sl_t2" readonly="1"/>
                                    <field name="tong_hang_di_duong_sl_t3" readonly="1"/>
                                    <field name="tong_hang_di_duong" string="Tổng đi đường" readonly="1"/>

                                    <field name="sl_du_tru_toi_thieu" string="Dự trữ tối thiểu" readonly="1"/>
                                    <field name="sl_dat_mua_de_xuat" string="Đề xuất đặt mua" readonly="1"/>
                                    <field name="sl_dat_mua_chot" string="Đặt mua chốt" readonly="1"/>
                                    <field name="sl_can_mua_theo_moq" string="SL mua theo MOQ"/>
                                    <field name="don_gia_mua" string="Đơn giá mua" widget="monetary" readonly="1"/>
                                    <field name="gia_tri_mua_hang" string="Giá trị mua" widget="monetary" readonly="1" force_save="1"/>
                                    <field name="sl_ton_kho_cuoi_ky" string="Tồn kho cuối kỳ" readonly="1" force_save="1"/>
                                    <field name="so_ngay_vong_quay_ton" string="Ngày vòng quay tồn" readonly="1" force_save="1"/>
                                    <field name="don_gia_ton_kho_cuoi_ky" string="Đơn giá tồn cuối kỳ" widget="monetary" readonly="1" force_save="1"/>
                                    <field name="gia_tri_ton_kho_cuoi_ky" string="Giá trị tồn cuối kỳ" widget="monetary" readonly="1" force_save="1"/>

                                    <field name="ghi_chu" readonly="1"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Phê duyệt">
                            <group>
                                <field name="approval_flow_id"
                                       readonly="approval_state != 'draft'"
                                       options="{'no_create': True, 'no_open': True}"
                                       domain="[('model_id.model', '=', 'ke.hoach.vat.tu'), ('dvcs', '=', approval_company_id)]"/>
                            </group>
                            <field name="approval_step_ids" readonly="1">
                                <tree create="false" delete="false" edit="false">
                                    <field name="sequence"/>
                                    <field name="phuong_thuc"/>
                                    <field name="vai_tro_id"/>
                                    <field name="nguoi_duyet_id"/>
                                    <field name="da_duyet"/>
                                    <field name="ngay_duyet"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

