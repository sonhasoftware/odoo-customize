<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ke_hoach_thanh_pham_tree" model="ir.ui.view">
        <field name="name">ke.hoach.thanh.pham.tree</field>
        <field name="model">ke.hoach.thanh.pham</field>
        <field name="arch" type="xml">
            <tree string="B1 - Kế hoạch thành phẩm" editable="bottom">
                <field name="period_id" required="1"/>
                <field name="nganh_hang_id"/>
                <field name="dong_hang_id"/>
                <field name="ma_hang_id" options="{'no_create': True}"/>
                <field name="ma_hang"/>
                <field name="ma_sap" readonly="1" required="1"/>
                <field name="month_key" required="1"/>
                <field name="qty" sum="SL"/>
            </tree>
        </field>
    </record>

    <record id="view_ke_hoach_thanh_pham_search" model="ir.ui.view">
        <field name="name">ke.hoach.thanh.pham.search</field>
        <field name="model">ke.hoach.thanh.pham</field>
        <field name="arch" type="xml">
            <search>
                <field name="period_id"/>
                <field name="ma_sap"/>
                <field name="ma_hang"/>
                <field name="company_id"/>
                <field name="nganh_hang_id"/>
                <field name="dong_hang_id"/>
                <field name="ma_hang_id"/>
                <field name="month_key"/>
                <group expand="0" string="Nhóm theo">
                    <filter name="group_period" string="Kỳ"
                            context="{'group_by': 'period_id'}"/>
                    <filter name="group_company" string="Công ty"
                            context="{'group_by': 'company_id'}"/>
                    <filter name="group_month" string="Tháng"
                            context="{'group_by': 'month_key'}"/>
                    <filter name="group_sap" string="Mã SAP"
                            context="{'group_by': 'ma_sap'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_ke_hoach_thanh_pham" model="ir.actions.act_window">
        <field name="name">B1 - Kế hoạch thành phẩm</field>
        <field name="res_model">ke.hoach.thanh.pham</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="view_ke_hoach_thanh_pham_search"/>
    </record>

</odoo>
