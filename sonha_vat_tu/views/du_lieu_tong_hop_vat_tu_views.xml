                            <field name="don_vi_tinh"/>
                            <field name="sl_dinh_muc"/>
                        </group>
                        <group>
                            <field name="ma_dat_hang"/>
                            <field name="chung_loai"/>
                            <field name="ton_dau"/>
                            <field name="ve_du_kien"/>
                            <field name="vt_can_dung"/>
                            <field name="ton_cuoi"/>
                            <field name="so_luong_du_phong"/>
                            <field name="so_luong_thieu"/>
                            <field name="so_luong_can_mua"/>
                            <field name="ghi_chu"/>
                            <field name="tong_ton_nvl_sl"/>
                            <field name="tong_hang_di_duong_sl"/>
                            <field name="tong_sl_vt_can_dung"/>
                            <field name="sl_du_tru_toi_thieu"/>
                            <field name="sl_can_mua_theo_moq"/>
                            <field name="sl_dat_mua_de_xuat"/>
                            <field name="sl_dat_mua_chot"/>
                            <field name="sl_ton_kho"/>
                            <field name="so_ngay_vong_quay_ton"/>
