    <record id="view_du_lieu_tong_hop_vat_tu_search" model="ir.ui.view">
        <field name="name">du.lieu.tong.hop.vat.tu.search</field>
        <field name="model">du.lieu.tong.hop.vat.tu</field>
        <field name="arch" type="xml">
            <search>
                <field name="step_code"/>
                <field name="period_id"/>
                <field name="company_id"/>
                <field name="period_company_id"/>
                <field name="period_code"/>
                <field name="period_month"/>
                <field name="company_code"/>
                <field name="period_company_code"/>
                <field name="month_key"/>
                <field name="ma_sap"/>
                <field name="ma_tp"/>
                <field name="ten_tp"/>
                <field name="ma_nvl"/>
                <field name="ten_nvl"/>
                <field name="ten_vat_tu"/>
                <field name="ma_effect"/>
                <field name="ma_dat_hang"/>
                <field name="source_model"/>
                <filter name="filter_kd" string="Kế hoạch kinh doanh" domain="[('step_code', '=', 'kd')]"/>
                <filter name="filter_sx" string="Kế hoạch sản xuất" domain="[('step_code', '=', 'sx')]"/>
                <filter name="filter_b1" string="B1" domain="[('step_code', '=', 'b1')]"/>
                <filter name="filter_b2" string="B2" domain="[('step_code', '=', 'b2')]"/>
                <filter name="filter_b3" string="B3" domain="[('step_code', '=', 'b3')]"/>
                <filter name="filter_b4" string="B4" domain="[('step_code', '=', 'b4')]"/>
                <filter name="filter_b5" string="B5" domain="[('step_code', '=', 'b5')]"/>
                <group expand="0" string="Nhóm">
                    <filter name="group_step" string="Bước" context="{'group_by': 'step_code'}"/>
                    <filter name="group_period" string="Kỳ" context="{'group_by': 'period_id'}"/>
                    <filter name="group_period_company" string="Đơn vị yêu cầu" context="{'group_by': 'period_company_id'}"/>
                    <filter name="group_period_code" string="Số chứng từ" context="{'group_by': 'period_code'}"/>
                    <filter name="group_period_month" string="Tháng bắt đầu" context="{'group_by': 'period_month'}"/>
                    <filter name="group_month" string="Tháng" context="{'group_by': 'month_key'}"/>
                    <filter name="group_company" string="Đơn vị sản xuất" context="{'group_by': 'company_id'}"/>
                    <filter name="group_ma_nvl" string="Mã NVL" context="{'group_by': 'ma_nvl'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_du_lieu_tong_hop_vat_tu" model="ir.actions.act_window">
        <field name="name">Dữ liệu tổng hợp vật tư</field>
        <field name="res_model">du.lieu.tong.hop.vat.tu</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_du_lieu_tong_hop_vat_tu_search"/>
    </record>

</odoo>
